{
  "name": "twitter_clone",
  "version": "1.0.0",
  "description": "Classic Twitter clone (MERN): timelines, reposts, DMs, Nest AI, profiles — deployed on Vercel + Render with JWT auth and Cloudinary.",
  "main": "backend/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon backend/server.js",
    "start": "cross-env NODE_ENV=production node backend/server.js",
    "build": "npm install && npm install --prefix frontend --include=dev && npm run build --prefix frontend"
  },
  "keywords": ["twitter-clone", "mern", "react", "mongodb", "portfolio", "social-media"],
  "author": "",
  "type": "module",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
